{
  "name": "labkom-admin",
  "version": "1.2.0",
  "description": "Dashboard administrasi dan pemantauan laboratorium komputer",
  "author": "LabKom",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev:react": "vite --port 5174",
    "build:react": "vite build",
    "verify:packaged-server": "node scripts/verify-packaged-server.cjs",
    "electron:dev": "set \"ELECTRON_RUN_AS_NODE=\" && concurrently \"npm.cmd run dev:react\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "set \"ELECTRON_RUN_AS_NODE=\" && npm.cmd run build:react && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.labkom.admin",
    "productName": "LabKom Admin - Dashboard",
    "artifactName": "LabKom-Admin-Dashboard-Setup-${version}.${ext}",
    "asar": true,
    "electronFuses": {
      "runAsNode": true,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": [
          "**/*",
          "!.env",
          "!.env.local",
          "!.env.*.local",
          "!firebase-service-account.json",
          "!*firebase-adminsdk*.json",
          "!serviceAccountKey.json",
          "!.git/**",
          "!node_modules/**",
          "!test/**",
          "!*.log"
        ]
      },
      {
        "from": "../server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*",
          "!nodemon/**"
        ]
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "shortcutName": "LabKom Admin",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "1oneGod1",
        "repo": "labmanager",
        "private": false,
        "channel": "admin",
        "releaseType": "release"
      }
    ]
  }
}
