# Salin ke %APPDATA%\LabKom Admin - Dashboard\server.env pada instalasi produksi.
# Jangan commit file berisi nilai asli.
PORT=3001
NODE_ENV=production

# Penyimpanan bawaan: SQLite lokal pada komputer Admin.
# Lokasi data produksi ditentukan otomatis oleh aplikasi Admin.
LABKOM_DATA_PROVIDER=sqlite
LABKOM_DATABASE_FILE=
LABKOM_BACKUP_RETENTION_DAYS=30
LABKOM_BACKUP_INTERVAL_HOURS=24

# Wajib berupa bcrypt hash. Buat dengan: npm run hash-admin-password -- <password>
ADMIN_PASSWORD=$2b$10$x7A71CHObExmQ7nqG0/pduYE1ye3TjjQqeMGa5qtWsA9q.ALnu6Te
# Penanda migrasi bawaan installer; jangan dihapus saat hanya mengganti password.
LABKOM_ADMIN_PASSWORD_POLICY_VERSION=2026-07-14-1

# Dibuat otomatis oleh aplikasi Admin pada pembukaan pertama.
# Kunci panjang dipertahankan untuk kompatibilitas client lama.
CLIENT_REGISTRATION_KEY=

# Kode 6 digit untuk pairing instalasi baru dan pemulihan client.
# Lihat kode ini pada menu Server di aplikasi Admin.
CLIENT_PAIRING_CODE=

# Dibuat otomatis dan dipertahankan agar token PC tetap valid setelah server restart.
CLIENT_TOKEN_SECRET=
